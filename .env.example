# Copier ce fichier vers .env à la racine du projet, puis remplir les valeurs.
# Ne jamais committer le fichier .env (il est dans .gitignore).

SUPABASE_URL=
SUPABASE_ANON_KEY=
BGG_APPLICATION_TOKEN=

# Livres : Google Books (recherche + ISBN) — https://console.cloud.google.com
GOOGLE_BOOKS_API_KEY=

# Vinyles / CD : Discogs (recommandé pour les vinyles) — https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Pokémon : TCGdex (gratuit, pas de clé) — pokemontcg.io / Scrydex ne sont plus utilisés
# Web (GitHub Pages) : GitHub → Settings → Secrets and variables → Actions
#   Coller les mêmes clés que ci-dessous (SUPABASE_*, BGG_*, GOOGLE_*, etc.)
#   + déployer supabase/functions/bgg-proxy et image-proxy sur Supabase

# Films (Blu-ray, DVD) — TMDB optionnel ; sans clé → recherche iTunes (gratuit)
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Jeux vidéo — RAWG optionnel ; sans clé → catalogue Steam (gratuit)
# https://rawg.io/apidocs
RAWG_API_KEY=

# Lego — Rebrickable optionnel ; sans clé → wiki Lego (gratuit)
# https://rebrickable.com/api/
REBRICKABLE_API_KEY=

# --- Optionnel : tests en local uniquement (mode debug, jamais en release) ---
# DEV_TEST_EMAIL=
# DEV_TEST_PASSWORD=
# DEV_LOGIN_LABEL=Connexion admin
# DEV_SKIP_SPLASH=true
# Ou en ligne de commande : flutter run --dart-define=DEV_SKIP_SPLASH=true
# Scripts : scripts/run-with-splash.ps1 | scripts/run-dev-fast.ps1
